# ============================================================
# MULTICORE ERP — Environment Variables Template
# Copy this file to .env and fill in REAL values.
# NEVER commit the real .env to git — only this example file.
# ============================================================

# ── App ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development            # Change to "production" in prod

# ── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/sistema_db"

# ── Security ─────────────────────────────────────────────────
# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="CHANGE_ME_TO_A_STRONG_RANDOM_SECRET_MIN_32_CHARS"
JWT_EXPIRES_IN="7d"

# Comma-separated allowed frontend origins (REQUIRED in production)
# Example: ALLOWED_ORIGINS="https://app.example.com,https://www.example.com"
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"
FRONTEND_URL="http://localhost:5173"

# ── Redis (optional — enables token revocation & distributed rate limiting) ──
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""
# Alternative to REDIS_URL (used when REDIS_URL is not set):
REDIS_HOST="localhost"
REDIS_PORT="6379"

# ── Email / SMTP ─────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE=false                        # Set to true when using port 465 (TLS)
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-gmail-app-password"  # Use App Password, not account password
SMTP_FROM_NAME="Multicore ERP"

# ── Google Drive (optional) ───────────────────────────────────
GDRIVE_ENABLED=false
GDRIVE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GDRIVE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"
GDRIVE_REDIRECT_URI="http://localhost:3001/api/gdrive/callback"
GDRIVE_REFRESH_TOKEN=""
GDRIVE_FOLDER_ID=""

# ── Google Gemini AI (optional) ──────────────────────────────
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GEMINI_MODEL="gemini-1.5-flash"         # Override default model (optional)

# ── M-Pesa (Moçambique — optional) ───────────────────────────
# Register at: https://developer.mpesa.vm.co.mz/
MPESA_API_KEY="YOUR_MPESA_API_KEY"
MPESA_PUBLIC_KEY=""
MPESA_SERVICE_PROVIDER_CODE=""
MPESA_API_HOST="api.sandbox.vm.co.mz"   # Use api.vm.co.mz in production
MPESA_ORIGIN=""
MPESA_CALLBACK_URL=""                   # REQUIRED in production: public URL for M-Pesa to POST callbacks (e.g. https://api.exemplo.co.mz/api/payments/mpesa/callback)
MPESA_FORCE_SIMULATION=false            # Set to true to use simulated M-Pesa in any env

# ── Telegram Notifications (optional) ────────────────────────
TELEGRAM_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
TELEGRAM_CHAT_ID=""
DEFAULT_COMPANY_ID=""                   # Company ID for Telegram webhook multi-tenancy

# ── n8n AI Webhook (optional) ────────────────────────────────
N8N_WEBHOOK_URL=""
N8N_TIMEOUT=30000

# ── Backup ────────────────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=30

# ── Mozambique Tax Defaults ────────────────────────────────────
DEFAULT_IVA_RATE=16
DEFAULT_INSS_EMPLOYEE_RATE=3
DEFAULT_INSS_EMPLOYER_RATE=4

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL="info"
SENTRY_DSN=""
