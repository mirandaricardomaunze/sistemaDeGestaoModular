// ============================================================================
model NarcoticRegister {
  id                String     @id @default(uuid())
  registerDate      DateTime
  medicationId      String
  medicationName    String
  batchNumber       String
  openingBalance    Int
  received          Int        @default(0)
  dispensed         Int        @default(0)
  returned          Int        @default(0)
  destroyed         Int        @default(0)
  closingBalance    Int
  discrepancy       Int        @default(0)
  notes             String?
  verifiedBy        String
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  companyId         String?
  company           Company?   @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([registerDate])
  @@map("narcotic_register")
}

// ============================================================================
// BATCH RECALLS
// ============================================================================
model BatchRecall {
  id             String            @id @default(uuid())
  recallNumber   String
  medicationId   String
  batchNumbers   String[]
  reason         String
  severity       String            // voluntary | mandatory | urgent
  issuedBy       String            // regulatory authority
  recallDate     DateTime
  status         BatchRecallStatus @default(active)
  affectedUnits  Int               @default(0)
  recoveredUnits Int               @default(0)
  notes          String?
  actionTaken    String?
  resolvedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  companyId      String?
  company        Company?          @relation(fields: [companyId], references: [id])
  medication     Medication        @relation(fields: [medicationId], references: [id])

  @@index([companyId])
  @@map("batch_recalls")
}

// ============================================================================
// PARTNER INVOICES (Billing to insurance/convenio partners)
// ============================================================================
model PartnerInvoice {
  id            String                @id @default(uuid())
  invoiceNumber String
  partnerId     String
  periodStart   DateTime
  periodEnd     DateTime
  totalAmount   Decimal               @db.Decimal(15, 2)
  paidAmount    Decimal               @default(0) @db.Decimal(15, 2)
  status        PartnerInvoiceStatus  @default(pending)
  dueDate       DateTime?
  notes         String?
  saleIds       String[]              @default([])
  paidAt        DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  companyId     String?
  company       Company?              @relation(fields: [companyId], references: [id])
  partner       PharmacyPartner       @relation(fields: [partnerId], references: [id])

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@map("partner_invoices")
}

model StockMovement {
  id            String           @id @default(uuid())
  batchId       String?
  movementType  MovementType
  quantity      Int
  balanceBefore Int
  balanceAfter  Int
  reference     String?
  reason        String?
  performedBy   String
  createdAt     DateTime         @default(now())
  companyId     String?
  originModule  String?
  productId     String?
  referenceType String?
  warehouseId   String?
  product       Product?         @relation(fields: [productId], references: [id])
  warehouse     Warehouse?       @relation(fields: [warehouseId], references: [id])
  batch         MedicationBatch? @relation(fields: [batchId], references: [id])

  @@index([companyId])
  @@index([originModule])
  @@index([productId])
  @@index([warehouseId])
  @@map("stock_movements")
}

