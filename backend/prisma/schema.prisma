  value     Json
  updatedAt DateTime @updatedAt
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  @@unique([companyId, metric])
  @@index([companyId])
  @@map("pharmacy_dashboard_cache")
}

// ============================================================================
// M-Pesa Payment Integration
// ============================================================================

model MpesaTransaction {
  id                String    @id @default(uuid())
  transactionId     String?   @unique // M-Pesa transaction ID
  conversationId    String? // M-Pesa conversation ID
  phone             String
  amount            Decimal   @db.Decimal(15, 2)
  reference         String // Internal reference (e.g., INV-2024-00001)
  status            String    @default("pending") // pending, processing, completed, failed, cancelled
  module            String // pos, invoice, hospitality, pharmacy
  moduleReferenceId String? // saleId, invoiceId, bookingId
  errorCode         String?
  errorMessage      String?
  requestPayload    Json? // Store request for debugging
  responsePayload   Json? // Store response for debugging
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  completedAt       DateTime?

  // Multi-tenancy
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([status])
  @@index([phone])
  @@index([transactionId])
  @@map("mpesa_transactions")
}

// ============================================================================
// LOGISTICS MODULE - Vehicles, Drivers, Routes, Deliveries, Parcels
// ============================================================================

model Vehicle {
  id              String               @id @default(uuid())
  plate           String
  brand           String
  model           String
  year            Int?
  type            VehicleType          @default(truck)
  capacity        Decimal?             @db.Decimal(10, 2)
  capacityUnit    String?              @default("kg")
  fuelType        String?
  status          VehicleStatus        @default(available)
  lastMaintenance DateTime?
  nextMaintenance DateTime?
  mileage         Int                  @default(0)
  insuranceExpiry DateTime?
  notes           String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  companyId       String?
  company         Company?             @relation(fields: [companyId], references: [id])
  maintenances    VehicleMaintenance[]
  deliveries      Delivery[]

  @@unique([companyId, plate])
  @@index([companyId])
  @@map("vehicles")
}

model Driver {
  id               String       @id @default(uuid())
  code             String
  name             String
  phone            String
  email            String?
  licenseNumber    String
  licenseType      String?
  licenseExpiry    DateTime?
  status           DriverStatus @default(available)
  hireDate         DateTime?
  address          String?
  emergencyContact String?
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  companyId        String?
  company          Company?     @relation(fields: [companyId], references: [id])
  deliveries       Delivery[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("drivers")
}

model VehicleMaintenance {
  id          String            @id @default(uuid())
  vehicleId   String
  type        MaintenanceType   @default(preventive)
  description String
  cost        Decimal           @db.Decimal(15, 2)
  date        DateTime          @default(now())
  nextDate    DateTime?
  mileageAt   Int?
  status      MaintenanceStatus @default(scheduled)
  provider    String?
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  vehicle     Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@map("vehicle_maintenances")
}

model DeliveryRoute {
  id            String     @id @default(uuid())
  code          String
  name          String
  origin        String
  destination   String
  distance      Decimal?   @db.Decimal(10, 2)
  estimatedTime Int? // em minutos
  tollCost      Decimal?   @db.Decimal(10, 2)
  fuelEstimate  Decimal?   @db.Decimal(10, 2)
  isActive      Boolean    @default(true)
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  companyId     String?
  company       Company?   @relation(fields: [companyId], references: [id])
  deliveries    Delivery[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("delivery_routes")
}

model Delivery {
  id              String           @id @default(uuid())
  number          String
  orderId         String?
  customerId      String?
  routeId         String?
  vehicleId       String?
  driverId        String?
  status          DeliveryStatus   @default(pending)
  priority        DeliveryPriority @default(normal)
  scheduledDate   DateTime?
  departureDate   DateTime?
  deliveredDate   DateTime?
  recipientName   String?
  recipientPhone  String?
  recipientSign   String? // Base64 da assinatura
  deliveryAddress String
  latitude        Decimal?         @db.Decimal(10, 8)
  longitude       Decimal?         @db.Decimal(11, 8)
  notes           String?
  proofOfDelivery String? // URL da foto
  failureReason   String?
  attempts        Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  companyId       String?
  company         Company?         @relation(fields: [companyId], references: [id])
  route           DeliveryRoute?   @relation(fields: [routeId], references: [id])
  vehicle         Vehicle?         @relation(fields: [vehicleId], references: [id])
  driver          Driver?          @relation(fields: [driverId], references: [id])
  country         String?          @default("Moçambique")
  province        String?
  city            String?
  shippingCost    Decimal?         @db.Decimal(15, 2)
  isPaid          Boolean          @default(false)
  transactionId   String?
  items           DeliveryItem[]
  transactions    Transaction[]

  @@unique([companyId, number])
  @@index([companyId])
  @@index([status])
  @@map("deliveries")
}

model DeliveryItem {
  id          String   @id @default(uuid())
  deliveryId  String
  productId   String?
  description String
  quantity    Int      @default(1)
  weight      Decimal? @db.Decimal(10, 2)
  notes       String?
  delivery    Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])

  @@index([deliveryId])
  @@map("delivery_items")
}

model Parcel {
  id                   String               @id @default(uuid())
  trackingNumber       String
  senderName           String
  senderPhone          String
  senderEmail          String?
  senderAddress        String?
  recipientName        String
  recipientPhone       String
  recipientEmail       String?
  recipientAddress     String?
  recipientDocument    String?
  description          String?
  weight               Decimal?             @db.Decimal(10, 2)
  dimensions           String? // "LxWxH cm"
  status               ParcelStatus         @default(received)
  receivedAt           DateTime             @default(now())
  expectedPickup       DateTime?
  pickedUpAt           DateTime?
  pickedUpBy           String? // Nome de quem levantou
  pickedUpDocument     String? // Documento de quem levantou
  pickupSignature      String? // Base64 da assinatura
  storageLocation      String? // Prateleira/local no armazém
  warehouseId          String?
  fees                 Decimal              @default(0) @db.Decimal(15, 2)
  isPaid               Boolean              @default(false)
  paymentMethod        String?
  notes                String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  companyId            String?
  company              Company?             @relation(fields: [companyId], references: [id])
  warehouse            Warehouse?           @relation(fields: [warehouseId], references: [id])
  receiverRelationship String? // Relação com o destinatário
  transactionId        String? // Link para transação financeira
  notifications        ParcelNotification[]
  transactions         Transaction[]

  @@unique([companyId, trackingNumber])
  @@index([companyId])
  @@index([status])
  @@index([recipientPhone])
  @@map("parcels")
}

model ParcelNotification {
  id        String           @id @default(uuid())
  parcelId  String
  type      NotificationType @default(email)
  recipient String
  message   String
  sentAt    DateTime         @default(now())
  status    String           @default("sent")
  errorMsg  String?
  parcel    Parcel           @relation(fields: [parcelId], references: [id], onDelete: Cascade)

  @@index([parcelId])
  @@map("parcel_notifications")
}

// ============================================================================
// BOTTLE STORE MODULE
// ============================================================================

model BottleReturn {
  id              String           @id @default(uuid())
  customerId      String?
  productId       String
  quantity        Int
  depositPaid     Decimal          @default(0) @db.Decimal(15, 2)
  depositRefunded Decimal          @default(0) @db.Decimal(15, 2)
  type            BottleReturnType @default(return)
  saleId          String?
  notes           String?
  performedBy     String
  createdAt       DateTime         @default(now())
  companyId       String?
  company         Company?         @relation(fields: [companyId], references: [id])
  customer        Customer?        @relation(fields: [customerId], references: [id])
  product         Product          @relation(fields: [productId], references: [id])
  sale            Sale?            @relation(fields: [saleId], references: [id])

  @@index([companyId])
  @@index([customerId])
  @@map("bottle_returns")
}

model CashSession {
  id              String            @id @default(uuid())
  openedById      String            @map("opened_by_id")
  closedById      String?           @map("closed_by_id")
  openedAt        DateTime          @default(now())
  closedAt        DateTime?
  openingBalance  Decimal           @db.Decimal(15, 2)
  closingBalance  Decimal?          @db.Decimal(15, 2)
  expectedBalance Decimal?          @db.Decimal(15, 2)
  difference      Decimal?          @db.Decimal(15, 2)
  cashSales       Decimal           @default(0) @db.Decimal(15, 2)
  mpesaSales      Decimal           @default(0) @db.Decimal(15, 2)
  emolaSales      Decimal           @default(0) @db.Decimal(15, 2)
  cardSales       Decimal           @default(0) @db.Decimal(15, 2)
  creditSales     Decimal           @default(0) @db.Decimal(15, 2)
  totalSales      Decimal           @default(0) @db.Decimal(15, 2)
  withdrawals     Decimal           @default(0) @db.Decimal(15, 2) // Sangrias
  deposits        Decimal           @default(0) @db.Decimal(15, 2) // Suprimentos
  notes           String?
  status          CashSessionStatus @default(open)
  companyId       String?
  terminalId      String?           @map("terminal_id")

  // Relations
  company         Company?          @relation(fields: [companyId], references: [id])
  openedBy        User              @relation("OpenedSessions", fields: [openedById], references: [id])
  closedBy        User?             @relation("ClosedSessions", fields: [closedById], references: [id])
  sales           Sale[]
  movements       CashMovement[]

  @@index([companyId])
  @@index([status])
  @@map("cash_sessions")
}

model CashMovement {
  id            String      @id @default(uuid())
  sessionId     String      @map("session_id")
  type          String      // "sangria" | "suprimento"
  amount        Decimal     @db.Decimal(15, 2)
  reason        String
  performedById String      @map("performed_by_id")
  createdAt     DateTime    @default(now())

  // Relations
  session       CashSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  performedBy   User        @relation(fields: [performedById], references: [id])

  @@index([sessionId])
  @@map("cash_movements")
}

model CreditPayment {
  id            String        @id @default(uuid())
  saleId        String
  customerId    String
  amount        Decimal       @db.Decimal(15, 2)
  paymentMethod PaymentMethod @default(cash)
  reference     String?
  notes         String?
  receivedBy    String
  paidAt        DateTime      @default(now())
  companyId     String?
  company       Company?      @relation(fields: [companyId], references: [id])
  customer      Customer      @relation(fields: [customerId], references: [id])
  sale          Sale          @relation(fields: [saleId], references: [id])

  @@index([companyId])
  @@index([saleId])
  @@index([customerId])
  @@map("credit_payments")
}

enum BottleReturnType {
  deposit // Cliente pagou caução
  return // Cliente devolveu vasilhame
  refund // Devolução do depósito
  adjustment // Ajuste manual
}

enum CashSessionStatus {
  open
  closed
  suspended
}

